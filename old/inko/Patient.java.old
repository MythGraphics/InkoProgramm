    public void setRxExpiringDate(Date date) {
        setValue( ENDE_GENEHMIGUNG, formatDate( date ));
    }

    public Calendar getRxExpiringDate() {
        return parseDate(ENDE_GENEHMIGUNG);
    }

    public boolean isRxExpiringExpected() {
        GregorianCalendar cal = new GregorianCalendar();
        cal.set( Calendar.DAY_OF_MONTH, 1);                                                                             // setze den Tag auf den 1. des Monats
        cal.add( Calendar.MONTH, 1 );                                                                                   // nächster Monat
        return getRxExpiringDate().before(cal);
    }

    public boolean isBindingExpiringExpected() {
        GregorianCalendar cal = new GregorianCalendar();
        cal.add( Calendar.MONTH, 1 );                                                                                   // nächsten Monat
        cal.set( Calendar.DAY_OF_MONTH, cal.getActualMaximum( Calendar.DAY_OF_MONTH ));                                 // setze den Tag auf den Letzten des Monats
        return getBindingExpiringDate().before(cal);
    }

    public boolean isBindingExpired() {
//      Date now = new GregorianCalendar().getTime();
        GregorianCalendar now = new GregorianCalendar();
        return getBindingExpiringDate().before(now);
    }

    public Calendar getBindingExpiringDate() {
        return parseDate(ENDE_BINDUNG);
    }

    public String getBindingExpiringDateAsString() {
        return formatShortDate( getBindingExpiringDate().getTime() );
    }

    public Calendar parseDate(int index) {
        try {
            return DateUtil.getCalendar( value[index], true );                                                          // fehlt der Wert "Tag", wird der letzte Tag des Monats gesetzt
        }
        catch (IllegalArgumentException | NoSuchElementException e) {
            System.err.println( value[index] + " ungültig.");
            System.err.println( "Datum unverständlich - Format unbekannt." );
            System.err.println( e.getMessage() );
            return null;
        }
    }

    public boolean toDeliver() {
        return SQLUtil.parseAnyBoolean( value[LIEFERN] );
    }

    public void setDeliver(boolean value) {
        setValue( LIEFERN, String.valueOf( value ));
    }

    public boolean hasNoCoPayment() {
        GregorianCalendar today = new GregorianCalendar();
        GregorianCalendar x = new GregorianCalendar(
            getCoPaymentExpiringDate().get(Calendar.YEAR),
            Calendar.DECEMBER, 31
        );
        return today.before(x);
    }

    public void setNoCoPaymentDate(Date value) {
        setValue( FREI, formatDate( value ));
    }

    public Calendar getCoPaymentExpiringDate() {
        try {
            return parseDate(FREI);
        }
        catch (IllegalArgumentException e) {
            return NICHTBEFREIT;
        }
    }

    /**
     * Collects all primary values as a string-object; every value in a new line.
     * Used for UI (JTextArea)
     * Starts with index 1.
     * @return all values as a single string
     */
    public String getDataAsString() {
        String s = "";
        for (int i = 1; i <= PARAM_NAME_STRING_LENGTH; ++i) {
            try {
                s += getValue(i);
            } catch (NullPointerException e) {
                System.err.println( "NULL in Patient, getDataAsString(): " + e.toString() );
                s += "NULL";
            }
            s += "\n";
        }
        return s;
    }

    public static String formatShortDate(Date d) {
        return DF_REDUCED.format(d);
    }

    public static String formatDate(Date d) {
        return DF.format(d);
    }

    public static String formatSQLDate(Date d) {
        return DF_SQL.format(d);
    }

    public static String formatDate(String dateString) {
        return formatDate( DateUtil.getCalendar( dateString, true ).getTime() );                                        // fehlt der Wert "Tag", wird der letzte Tag des Monats gesetzt
    }

    @Override
    public boolean equals(Object obj) {
        if (this == obj) {
            return true;
        }
        if ( obj == null || getClass() != obj.getClass() ) {
            return false;
        }
        Patient pat = (Patient) obj;
        boolean b1 = getCompareString().equals( pat.getCompareString() );
        boolean b2 = getBirthDate().equals( pat.getBirthDate() );
        return b1 && b2;
    }

    @Override
    public int hashCode() {
        int hash = 3;
        hash = 97 * hash + Arrays.deepHashCode(this.value);
        return hash;
    }

    public static boolean isEqual(String lastName, String firstName, String dateOfBirth, Patient ref) {
        if ( !lastName.equals( ref.getLastName() )) { return false; }
        if ( !firstName.equals( ref.getFirstName() )) { return false; }
        if ( !dateOfBirth.equals( ref.getBirthDate() )) { return false; }
        return true;
    }

    /**
     * LastName, FirstName
     * @return compare-string
     */
    public String getCompareString() {
        return getLastName() + ", " + getFirstName();
    }

    @Override
    public int compareTo(Patient ref) {
        if (ref == null) {
            return 1;
        }
        int length;
        char[] a = getCompareString().toCharArray();
        char[] b = ref.getCompareString().toCharArray();
        if (a.length < b.length) {
            length = a.length;
        } else {
            length = b.length;
        }
        for (int i = 0; i < length; ++i) {
            if ( a[i] < b[i] ) {return -1;}
            if ( a[i] > b[i] ) {return  1;}
        }
        if (a.length == b.length) {return  0;}
        if (a.length >  b.length) {return  1;}
        else                      {return -1;}
    }

    @Override
    public String toString() {
        return getCompareString();
    }

    /**
     * Replaces all placeholder from PARAM_TEMPLATE to the values of Patient.
     * The elements of the ArrayList will be change to the replaced ones.
     * @param lines the Strings with the placeholders to be replaced
     * @param p Patient containing the replacement data
     */
    public static void replaceTemplates(ArrayList<String> lines, Patient p) {
        String[] template = Patient.PARAM_TEMPLATE;
        for (int i = 0; i < lines.size(); ++i) {
            for (int j = 0; j < template.length; ++j) {
                if ( lines.get(i).contains( template[j] )) {
                    lines.set( i, lines.get(i).replace( template[j], p.getValue(j) ));
        }}}
    }

    /**
     *
     * @param source the source string
     * @param index the index for FILE_PARAMS to be replaced
     * @param replacement the replacing substring
     * @return replaced string
     */
    public static String replace(String source, String replacement, int index) {
        return source.replaceAll( PARAM_TEMPLATE[index], replacement );
    }

    /**
     *
     * @param source the source string
     * @param replacement the array containing the replacing substrings
     * @return replaced string
     */
    public static String replaceAll(String source, String[] replacement) {
        String repl = source;
        for (int i = 0; i < replacement.length; ++i) {
            repl = repl.replaceAll( PARAM_TEMPLATE[i], replacement[i] );
        }
        return repl;
    }

}
