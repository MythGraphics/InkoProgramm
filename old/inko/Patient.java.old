    public String getComment() {
        // "pause_"-Präfix entfernen
        String raw = getRawValue(KOMMENTAR);
        if ( raw.startsWith( "pause_" )) {
            raw = raw.substring(6);
        }
        return raw;
    }

    public void setComment(String comment) {
        value[KOMMENTAR] = comment;
        if ( comment != null && !comment.isEmpty() ) {
            paused = comment.startsWith( "pause_" );
        } else {
            paused = false;
        }
    }

    public Calendar getRxDate() {
        return parseDate(RXDATUM);
    }

    public static Date getDate(String date) {
        return DateUtil.getCalendar( date ).getTime();
    }

    public static Date getDate(Calendar date) {
        return date.getTime();
    }

    public void setRxDate(Date date) {
        setValue( RXDATUM, formatDate( date ));
    }

    public String getRxDateAsString() {
        return getValue(RXDATUM);
    }

    public Date getFirstSupply() {
        return DateUtil.getCalendar( value[ERSTBELIEFERUNG] ).getTime();
    }

